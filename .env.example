# ─── Backend API ───────────────────────────────────────────────────────────────
# LOCAL DEV: leave blank — Vite proxy forwards /api → localhost:8000
# PRODUCTION: set to your deployed backend URL, e.g. https://your-api.onrender.com/api
VITE_API_URL=

# ─── Google OAuth ──────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=

# ─── Optional: RapidAPI Judge0 (code execution) ────────────────────────────────
# VITE_RAPIDAPI_KEY=
