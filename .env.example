# Backend API URL
# In LOCAL DEV: leave this unset (or blank) — the Vite proxy handles /api → localhost:8000
# In PRODUCTION: set this to your full backend URL, e.g. https://api.yourdomain.com/api
# VITE_API_URL=https://api.yourdomain.com/api

# Optional: RapidAPI Judge0 Key (for code execution if not proxied via backend)
# VITE_RAPIDAPI_KEY=https://judge0-ce.p.rapidapi.com
